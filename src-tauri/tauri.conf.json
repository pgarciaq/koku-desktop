{
  "productName": "Cost Management Desktop",
  "version": "0.2.0",
  "identifier": "com.redhat.koku-desktop",
  "build": {
    "frontendDist": "./frontend-stub",
    "devUrl": "http://localhost:9001"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../ui": "ui",
      "../settings": "settings",
      "../about": "about",
      "../splash": "splash"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
